# Copia este archivo a `.env` y rellena tus valores. NO subas `.env` a git.

# Secreto para firmar la cookie de sesión (cámbialo por algo largo y aleatorio)
RB_SESSION_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# API keys de IA (se usan SOLO en el servidor, nunca llegan al navegador)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Opcionales
# RB_ALLOW_REGISTER=0        # cierra el registro tras crear tu usuario
# RB_COOKIE_SECURE=1         # actívalo cuando sirvas por HTTPS
# RB_DB_PATH=./report_builder.db
