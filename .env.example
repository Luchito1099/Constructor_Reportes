# Copia a `.env` (en la raíz) y rellena tus valores. NO subas `.env` a GitHub.
# Lo lee docker-compose. Para correr sin Docker, usa backend/.env.

RB_SESSION_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# API keys de IA (solo en el servidor, nunca llegan al navegador)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Opcionales
RB_ALLOW_REGISTER=1      # pon 0 para cerrar el registro tras crear tu usuario
RB_COOKIE_SECURE=0       # 1 cuando sirvas por HTTPS
